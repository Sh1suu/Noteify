<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:background="#FFFFFF"
    android:elevation="8dp">

    <!-- Notes Tab -->
    <LinearLayout
        android:id="@+id/btnNavNotes"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:focusable="true"
        android:clickable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:id="@+id/iconNotes"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_notes"
            android:contentDescription="@string/nav_label_notes"/>

        <TextView
            android:id="@+id/labelNotes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_label_notes"
            android:textSize="11sp"
            android:layout_marginTop="3dp"/>
    </LinearLayout>

    <!-- Home Tab (Purple Circle) -->
    <LinearLayout
        android:id="@+id/btnNavHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:focusable="true"
        android:clickable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless">

        <LinearLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:gravity="center"
            android:background="@drawable/circle_purple">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_home"
                android:tint="#FFFFFF"
                android:contentDescription="@string/nav_dashboard"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Profile Tab -->
    <LinearLayout
        android:id="@+id/btnNavProfile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:focusable="true"
        android:clickable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:id="@+id/iconProfile"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_profile"
            android:contentDescription="@string/nav_label_profile"/>

        <TextView
            android:id="@+id/labelProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_label_profile"
            android:textSize="11sp"
            android:layout_marginTop="3dp"/>
    </LinearLayout>

</LinearLayout>