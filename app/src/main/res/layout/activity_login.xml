<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#181820"
    android:padding="28dp"
    android:gravity="center_horizontal">

    <ImageView
        android:layout_width="72dp"
        android:layout_height="90dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/noteifylogo"
        android:contentDescription="@string/cd_app_logo"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/app_name"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="40dp"
        android:text="@string/text_tagline"
        android:textColor="#AAAAAA"
        android:textSize="15sp"/>

    <!-- Email field -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_email"
        android:textColor="#8F8F9D"
        android:textSize="13sp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#252530"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/mail"
            android:contentDescription="@string/cd_email_icon"
            app:tint="#5A5A68"/>

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:background="@android:color/transparent"
            android:hint="@string/hint_email"
            android:textColorHint="#5A5A68"
            android:textColor="#FFFFFF"
            android:inputType="textEmailAddress"
            android:textSize="15sp"/>
    </LinearLayout>

    <!-- Password field -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_password"
        android:textColor="#8F8F9D"
        android:textSize="13sp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#252530"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/lock"
            android:contentDescription="@string/cd_lock_icon"
            app:tint="#5A5A68"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:background="@android:color/transparent"
            android:hint="@string/hint_password"
            android:textColorHint="#5A5A68"
            android:textColor="#FFFFFF"
            android:inputType="textPassword"
            android:textSize="15sp"/>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/eye"
            android:contentDescription="@string/cd_eye_icon"
            app:tint="#5A5A68"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/text_forgot_password"
        android:textColor="#b67bf0"
        android:textSize="13sp"
        android:gravity="end"
        android:textStyle="bold"/>

    <Button
        android:id="@+id/btnSignIn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="28dp"
        app:backgroundTint="@null"
        android:background="#9b51e0"
        android:text="@string/btn_sign_in"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text_no_account"
            android:textColor="#8F8F9D"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvCreateAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text_create_one"
            android:textColor="#b67bf0"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <ImageButton
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="#252530"
            android:src="@drawable/google"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:contentDescription="@string/cd_google_sign_in"/>

        <Space
            android:layout_width="20dp"
            android:layout_height="wrap_content"/>

        <ImageButton
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="#252530"
            android:src="@drawable/facebook"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:contentDescription="@string/cd_facebook_sign_in"/>
    </LinearLayout>

</LinearLayout>