<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F2F7">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:title="@string/title_edit_note"
        app:titleTextColor="#111111"
        app:navigationIcon="@drawable/ic_back"
        app:navigationContentDescription="@string/cd_back_icon"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_edit_note"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_title"
                    android:textColor="#444444"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etNoteTitle"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="#F2F2F7"
                    android:hint="@string/hint_note_title"
                    android:textColorHint="#AAAAAA"
                    android:textColor="#111111"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_subject"
                    android:textColor="#444444"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etSubject"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="#F2F2F7"
                    android:hint="@string/hint_subject"
                    android:textColorHint="#AAAAAA"
                    android:textColor="#111111"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="15sp"
                    android:inputType="textCapWords"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_content"
                    android:textColor="#444444"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etNoteContent"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="#F2F2F7"
                    android:hint="@string/hint_note_content"
                    android:textColorHint="#AAAAAA"
                    android:textColor="#111111"
                    android:padding="16dp"
                    android:textSize="15sp"
                    android:gravity="top"
                    android:inputType="textMultiLine"/>

                <CheckBox
                    android:id="@+id/cbImportant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/label_mark_important"
                    android:textColor="#444444"
                    android:textSize="14sp"
                    android:buttonTint="#9b51e0"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp">

                    <Button
                        android:id="@+id/btnCancel"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="@string/btn_cancel"
                        android:textAllCaps="false"
                        android:textColor="#555555"
                        android:textSize="15sp"
                        android:background="#F2F2F7"
                        app:backgroundTint="@null"/>

                    <Button
                        android:id="@+id/btnSaveNote"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="@string/btn_save_note"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:background="#9b51e0"
                        app:backgroundTint="@null"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </ScrollView>

    <include layout="@layout/bottom_nav_bar"/>

</LinearLayout>