<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <!--
        Circular avatar — Coil loads the saved image here.
        The ImageView is clipped to a circle programmatically via
        Coil's CircleCropTransformation so no third-party library is needed.
    -->
    <ImageView
        android:id="@+id/ivNavAvatar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_default_avatar"
        android:scaleType="centerCrop"
        android:contentDescription="@string/cd_profile_picture"/>

    <TextView
        android:id="@+id/tvNavName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="John Doe"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvNavEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="student@university.edu"
        android:textColor="#8F8F9D"
        android:textSize="14sp" />

</LinearLayout>